{
  "name": "codex-remote-backend",
  "version": "1.0.0",
  "description": "Local backend server for Codex CLI remote control",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "npm rebuild node-pty",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node --project tsconfig.json src/index.ts",
    "rebuild-pty": "npm rebuild node-pty",
    "smoke:terminal": "npm run build && node scripts/smoke-terminal.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/websocket": "^8.3.1",
    "better-sqlite3": "^12.9.0",
    "fastify": "^4.26.2",
    "js-yaml": "^4.1.0",
    "node-pty": "^1.1.0",
    "pino-pretty": "^13.1.3",
    "tree-kill": "^1.2.2",
    "uuid": "^9.0.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.30",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.3"
  }
}
